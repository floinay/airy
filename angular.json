          }
        }
      }
    },
    "tooltip": {
      "projectType": "library",
      "root": "projects/tooltip",
      "sourceRoot": "projects/tooltip/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
