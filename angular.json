          "options": {
            "tsConfig": "projects/icon/tsconfig.lib.json",
            "project": "projects/icon/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/icon/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
